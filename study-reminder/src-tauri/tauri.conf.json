{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "StudyReminder",
  "version": "0.1.0",
  "identifier": "com.studyreminder.app",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd /d d:\\code\\code-vs\\study-reminder\\frontend && pnpm dev",
    "beforeBuildCommand": "cd /d d:\\code\\code-vs\\study-reminder\\frontend && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "StudyReminder",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
